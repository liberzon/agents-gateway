# Database Configuration
DB_DRIVER=postgresql+psycopg
DB_USER=postgres
DB_PASS=your-db-password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=agentsdb

# Service URLs
SERVICE_PROMPTS=

# Prompt Storage Backend: "postgres" (default), "langsmith", or "service"
PROMPT_STORAGE_BACKEND=service

# =============================================================================
# API KEYS
# =============================================================================
# At least one model provider API key is required
GOOGLE_API_KEY=your-google-api-key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================================
# AUTHENTICATION
# =============================================================================
# Admin secret for /admin/* endpoints (required in production)
ADMIN_SECRET=your-admin-secret

# Fernet encryption key for token data (auto-generated if missing)
SECRET_TOKEN_ENC_KEY=

# Set to "true" to disable all authentication (development only)
# AUTH_DISABLED=true

# =============================================================================
# GUARDRAILS
# =============================================================================
# Enable prompt injection detection and PII masking
ENABLE_GUARDRAILS=false

# =============================================================================
# VECTOR DATABASE
# =============================================================================
QDRANT_URL=http://127.0.0.1
QDRANT_PORT=6333
QDRANT_API_KEY=

# =============================================================================
# OBSERVABILITY CONFIGURATION
# =============================================================================
OTEL_SERVICE_NAME=agents-gateway
OTEL_SERVICE_VERSION=1.0.0
OTEL_ENVIRONMENT=development

# Tracing Backend (choose one: none, console, otlp, jaeger, sentry)
OTEL_TRACING_BACKEND=console
OTEL_TRACING_SAMPLE_RATE=1.0

# Logging Backend (comma-separated: console, otlp, logtail)
OTEL_LOGGING_BACKEND=console
OTEL_LOG_LEVEL=INFO

# OTLP Collector (for 'otlp' backend)
# OTEL_OTLP_ENDPOINT=http://localhost:4317
# OTEL_OTLP_INSECURE=true

# Jaeger (for 'jaeger' backend)
# OTEL_JAEGER_AGENT_HOST=localhost
# OTEL_JAEGER_AGENT_PORT=6831

# Legacy: Better Stack/Logtail (for 'logtail' logging backend)
# BETTERSTACK_SOURCE_TOKEN=your-token-here
# BETTERSTACK_HOST=

# Legacy: Sentry (for 'sentry' tracing backend)
# SENTRY_DSN=https://your-dsn@sentry.io/xxx

# =============================================================================
# MISC
# =============================================================================
ENVIRONMENT=development
TESTING=false
CONCURRENT_FUTURES_TIMEOUT=180
